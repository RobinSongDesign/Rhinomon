<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net7.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <!-- Rhino plug-ins are .rhp files (renamed .dll). -->
    <TargetExt>.rhp</TargetExt>
    <Version>0.1.0</Version>
    <Company>Rhinomon</Company>
    <Product>Rhinomon</Product>
    <Description>A tiny pixel pet living in your Rhino viewport.</Description>
    <!-- RhinoCommon.dll is provided by the Rhino installation at runtime. -->
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <!-- net7.0 matches Rhino 8's bundled runtime; keep newer SDKs from raising
         end-of-life TFM warnings so the build stays warning-free everywhere. -->
    <CheckEolTargetFramework>false</CheckEolTargetFramework>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="RhinoCommon" Version="8.*" ExcludeAssets="runtime" />
  </ItemGroup>

  <!-- Sprite sheets generated by tools/spritegen. Wildcards keep the build
       working while the assets directory is still empty. -->
  <ItemGroup>
    <EmbeddedResource Include="..\..\assets\*.png" Link="Assets\%(Filename)%(Extension)" />
    <EmbeddedResource Include="..\..\assets\atlas.json" Link="Assets\atlas.json" Condition="Exists('..\..\assets\atlas.json')" />
  </ItemGroup>

</Project>
